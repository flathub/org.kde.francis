{
    "id": "org.kde.francis",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "francis",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland"
    ],
    "separate-locales": false,
    "cleanup": [
        "/lib/cmake"
    ],
    "modules": [
        {
            "name": "francis",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DCMAKE_BUILD_TYPE=Release"
            ],
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/25.08.3/src/francis-25.08.3.tar.xz",
                    "sha256": "a3bd44a252878fb5e145165806a1baa71b7e40be93ed94d5bd8777187595fe31",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/francis-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
